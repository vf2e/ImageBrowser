aesthetics/eat-repo/
aesthetics/venv/
aesthetics/hf_cache/
aesthetics/config.json

# Weights: download via scripts\setup_aesthetics.bat (keep README + .gitkeep)
aesthetics/weights/*.pth
aesthetics/weights/_gdrive/
!aesthetics/weights/.gitkeep
!aesthetics/weights/README.md

